{
  "name": "tarot",
  "version": "0.0.0",
  "description": "Tarot CLI",
  "type": "module",
  "bin": {
    "tarot": "./dist/cli.js",
    "tarot-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/data/interpretations && cp src/data/cards.json dist/data/cards.json && cp src/data/interpretations/*.json dist/data/interpretations/ 2>/dev/null || true",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "start": "node dist/cli.js",
    "start:mcp": "node dist/mcp.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.7.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
